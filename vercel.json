{
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" },
    { "src": "Menu/images/**", "use": "@vercel/static" },
    { "src": "static/images/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/menu-image/(.*)", "dest": "/Menu/images/$1" },
    { "src": "/static/images/(.*)", "dest": "/static/images/$1" },
    { "src": "/(.*)", "dest": "api/index.py" }
  ]
}
